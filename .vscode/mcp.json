{
  "servers": {
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"]
    },
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    },
    "Sentry": {
      "url": "https://mcp.sentry.dev/mcp"
    },
    "XcodeBuildMCP": {
      "command": "npx",
      "args": ["-y", "xcodebuildmcp@beta", "mcp"]
    },
    "nano-banana": {
      "type": "stdio",
      "command": "node",
      "args": ["/Users/pierceboggan/Documents/GitHub/nano-banana-mcp/dist/index.js"],
      "env": {
        "GOOGLE_API_KEY": "${input:google-api-key}"
      }
    }
  },
  "inputs": [
    {
      "id": "google-api-key",
      "type": "promptString",
      "description": "Google AI Studio key",
      "password": true

    }
  ]
}